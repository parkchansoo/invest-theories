# ============================================
# 투자 리서치 워크스페이스 — API 설정
# ============================================
# 이 파일을 .env 로 복사한 뒤 값을 채우세요:
#   cp .env.example .env
#
# .env 파일은 절대 git에 커밋하지 마세요!
# ============================================

# --- YouTube Data API (유튜브 자막 수집) ---
YOUTUBE_API_KEY=

# --- 증권사 API (사용하는 증권사만 설정) ---

# 키움증권 (OpenAPI REST)
# 발급: https://openapi.kiwoom.com/ → API 이용 신청
# 주의: IP 등록 필요 (포털에서 본인 IP 등록, 최대 10개)
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_ACCOUNT_NO=
KIWOOM_IS_MOCK=true

# 한국투자증권 (Open Trading API)
# 발급: https://apiportal.koreainvestment.com/ → 앱 등록
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT=

# 토스증권 (비공식 — tossctl CLI 필요)
# 설정: tossctl auth login → cd _scripts && ./toss_sync.sh
# 별도 API 키 불필요, 세션 파일로 동작

# --- MCP 서버 토큰 ---

# 키움 MCP (kiwoommcp.cleavework.com)
# 가입 후 발급받은 토큰을 입력
KIWOOM_MCP_TOKEN=
